# App
NODE_ENV=development
PORT=5000

# Admin panel
ADMIN_EMAIL=admin@toast.app
ADMIN_PASSWORD=admin_123
SESSION_SECRET=dev-session-secret-replace-in-prod
GOOGLE_PLACES_API_KEY=AIzaSyBl5BIF18xXyZFiYQ9DcG_9kUmaBP1ZTxk
# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5439/toast

# LINE LIFF
# Create a LIFF app in LINE Developers console and paste the LIFF ID here.
VITE_LIFF_ID=2009257970-yD2Hc8Zt
LINE_CHANNEL_ID=2009257970
ADMIN_LINE_USER_IDS=U1234567890abcdef,Uabcdef1234567890

# If true, app triggers LIFF login automatically when LIFF is initialized and user is not logged in.
# Recommended false for local dev, true for production LIFF-only entry points.
VITE_LIFF_AUTO_LOGIN=false




# Provider fallback policy: none | osm-error-only | google-first
# osm-error-only = use Google only when OSM returns empty or errors (recommended)
# none           = OSM only, zero Google spend
# google-first   = prefer Google, fall back to OSM
PROVIDER_FALLBACK=osm-error-only

# Google spend controls
PHOTO_ENRICH_LIMIT=20
GOOGLE_DAILY_BUDGET_USD=5.00

# Cache TTLs in milliseconds
CACHE_TTL_PLACES=604800000
CACHE_TTL_GEOCODE=1209600000

# Minimum OSM result count before accepting the cache as sufficient
MIN_RESULTS_BEFORE_CACHE=5
