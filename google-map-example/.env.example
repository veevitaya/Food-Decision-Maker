PORT=4000
PROVIDER_FALLBACK=google
GOOGLE_PLACES_API_KEY=YOUR_KEY_HERE
CACHE_TTL_PLACES=604800000
CACHE_TTL_GEOCODE=1209600000
# หรือใช้คำว่า never / infinite เพื่อตั้งไม่ให้หมดอายุ
# CACHE_TTL_PLACES=never
PREFETCH_INTERVAL_MS=43200000
PREFETCH_BBOXES=[{"lat":13.7563,"lon":100.5018,"radius":2000,"query":"restaurant"},{"lat":18.7883,"lon":98.9853,"radius":2000,"query":"restaurant"},{"lat":7.9519,"lon":98.3381,"radius":2000,"query":"restaurant"}]
DB_PATH=data/app.db
GOOGLE_PHOTO_ENRICH=true
PHOTO_ENRICH_LIMIT=50
MIN_RESULTS_BEFORE_CACHE=5
