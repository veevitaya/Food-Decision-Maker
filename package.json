{
  "name": "food-decision-maker-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @toast/frontend --filter @toast/admin --filter @toast/api dev",
    "dev:frontend": "pnpm --filter @toast/frontend dev",
    "dev:admin": "pnpm --filter @toast/admin dev",
    "dev:api": "pnpm --filter @toast/api dev",
    "build": "pnpm -r --filter @toast/frontend --filter @toast/admin --filter @toast/api build",
    "build:prod": "NODE_ENV=production pnpm -r --filter @toast/frontend --filter @toast/admin --filter @toast/api build",
    "start": "pnpm -r --parallel --filter @toast/frontend --filter @toast/admin --filter @toast/api start",
    "check": "pnpm -r --filter @toast/frontend --filter @toast/admin --filter @toast/api check",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env script/seed.ts",
    "db:seed:replace": "tsx --env-file=.env script/seed.ts --replace",
    "test": "vitest run",
    "test:watch": "vitest"
  },
