# -------------------------------
# Core runtime
# -------------------------------
NODE_ENV=production
API_PORT=5002
ADMIN_PORT=5001
FRONTEND_PORT=5000

# -------------------------------
# Security / auth
# -------------------------------
SESSION_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_USERNAME=admin

# -------------------------------
# Database
# -------------------------------
DATABASE_URL=postgres://postgres:postgres@db:5432/toast

# -------------------------------
# CORS
# -------------------------------
CORS_ORIGINS=https://staging-app.example.com,https://staging-admin.example.com

# -------------------------------
# Redis event ingest
# -------------------------------
REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT_MS=1500

EVENT_INGEST_MODE=redis
EVENT_REDIS_FAILURE_MODE=direct
EVENT_STREAM_KEY=events:ingest
EVENT_CONSUMER_GROUP=events-workers
EVENT_BATCH_SIZE=200
EVENT_FLUSH_INTERVAL_MS=2000
EVENT_MAX_RETRIES=3

# -------------------------------
# Queue monitor / alerts
# -------------------------------
QUEUE_MONITOR_INTERVAL_MS=60000
QUEUE_ALERT_MAX_LAG=2000
QUEUE_ALERT_MAX_PENDING=1000
QUEUE_ALERT_MAX_DLQ=0

# -------------------------------
# Test route exposure
# staging: true, production: false
# -------------------------------
VITE_ENABLE_TEST_ROUTE=true

# -------------------------------
# Optional integrations
# -------------------------------
VITE_LIFF_ID=
LINE_CHANNEL_ID=
VITE_LIFF_AUTO_LOGIN=false
